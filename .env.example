# Copy this file to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string
DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes_gateway

# Postgres connection string for the workflow-backend database (direct DB access)
WORKFLOW_DATABASE_URL=postgresql://user:pass@localhost:5432/workflow_backend

# Anthropic API key (used when HERMES_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ── Required for artifact write tools ─────────────────────────────────────────

# GitHub PAT with contents:write scope
# Used by workflow_write_product_spec / workflow_write_technical_design
GITHUB_TOKEN=github_pat_...

# ── Optional ──────────────────────────────────────────────────────────────────

# Server port (default: 8000)
# PORT=8000

# Model and provider (defaults shown)
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_PROVIDER=anthropic

# Shared service token presented by the workflow-bff as
# `Authorization: Bearer <token>`. Must match workflow-bff `internal_token`.
# The gateway trusts the BFF-injected X-User-Id / X-Org-Id headers only behind
# this token. When unset, the token check is skipped (local / direct use) and
# identity falls back to the request body.
# GATEWAY_SERVICE_TOKEN=
