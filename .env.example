# Environment configuration for the workflow gateway + plugin.
# Copy to .env and fill in. The vendored upstream agent has its own extensive
# .env.example at vendor/hermes-agent/.env.example — consult it for the full set
# of agent/provider options; the variables below are the workflow-specific ones.
# The gateway service also reads workflow_gateway/.env.

# =============================================================================
# WORKFLOW GATEWAY (digital-factory / M3 agent chat)
# =============================================================================

# Anthropic API key — required when provider=anthropic (claude-sonnet-4-6)
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token — contents:write scope required for artifact
# writes in T5 (workflow_write_product_spec / workflow_write_technical_design)
# GITHUB_TOKEN=github_pat_...

# Workflow-backend base URL — used by workflow_plugin tools to call
# /api/workspaces/{id} and /api/workspaces/{id}/features/{id}
# WORKFLOW_BACKEND_URL=http://localhost:8080

# Postgres connection string — used by workflow_gateway session store
# (voyager_sessions_v4 / voyager_messages_v4 tables)
# DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes_gateway

# Optional model/provider overrides for the workflow gateway
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_PROVIDER=anthropic
