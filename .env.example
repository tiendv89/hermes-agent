# Copy this file to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string
DATABASE_URL=postgresql://hermes_agent:hermes_agent@localhost:25434/hermes_agent

# Anthropic API key (used when HERMES_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# DeepSeek API key (used for DeepSeek models — deepseek-chat / deepseek-reasoner).
# Required only if users select a DeepSeek model in the chat model picker.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Required for artifact write tools ─────────────────────────────────────────

# GitHub PAT with contents:write scope
# Used by workflow_write_product_spec / workflow_write_technical_design
GITHUB_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────

# Default chat model when a request/session doesn't pick one. Optional — must be
# a supported catalog id (GET /api/v1/models); otherwise the server falls back to
# claude-sonnet-4-6. The model picker selects per turn; the provider is derived
# from the model id, so HERMES_PROVIDER is not needed.
HERMES_MODEL=claude-sonnet-4-6

PORT=8010

# Shared service token — must match workflow-bff `internal_token`.
GATEWAY_SERVICE_TOKEN=123456

GITNEXUS_MCP_URL=https://gitnexus.tempestdev.xyz
RAG_MCP_URL=https://rag.tempestdev.xyz

USER_SERVICE_URL=http://localhost:8082
USER_SERVICE_TOKEN=123456

NOTIFICATION_SERVICE_URL=http://localhost:8085
NOTIFICATION_SERVICE_TOKEN=123456

WORKFLOW_BACKEND_URL=http://localhost:8080
WORKFLOW_BACKEND_SERVICE_TOKEN=123456

# ── storage-service (required for go-owned feature document proxy) ────────────
# Used by the four document tools (read_document / write_product_spec /
# write_technical_design / edit_document) to proxy reads and writes for
# go-owned features to storage-service instead of GitHub.
STORAGE_SERVICE_URL=http://localhost:8090
STORAGE_SERVICE_TOKEN=