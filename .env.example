# Copy this file to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string
DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes_gateway

# Postgres connection string for the workflow-backend database (direct DB access)
WORKFLOW_DATABASE_URL=postgresql://user:pass@localhost:5432/workflow_backend

# Anthropic API key (used for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API key (used for DeepSeek models — deepseek-chat / deepseek-reasoner).
# Required only if users select a DeepSeek model in the chat model picker.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Required for artifact write tools ─────────────────────────────────────────

# GitHub PAT with contents:write scope
# Used by write_product_spec / write_technical_design
GITHUB_TOKEN=github_pat_...

# ── Optional ──────────────────────────────────────────────────────────────────

# Management-repo override for document writes. Only needed when the workspace's
# github source is not configured in the workflow-backend (get_workspace_context
# returns repos: []). Accepts a git URL or a plain "owner/repo".
# MANAGEMENT_REPO_GITHUB=git@github.com:my-org/my-workspace.git

# Server port (default: 8000)
# PORT=8000

# Default chat model when a request/session doesn't pick one. Optional — must be
# a supported catalog id (GET /api/v1/models); otherwise the server falls back to
# claude-sonnet-4-6. The model picker selects per turn; the provider is derived
# from the model id, so HERMES_PROVIDER is not needed.
# HERMES_MODEL=claude-sonnet-4-6

# Shared service token presented by the workflow-bff as
# `Authorization: Bearer <token>`. Must match workflow-bff `internal_token`.
# The gateway trusts the BFF-injected X-User-Id / X-Org-Id headers only behind
# this token. When unset, the token check is skipped (local / direct use) and
# identity falls back to the request body.
# GATEWAY_SERVICE_TOKEN=
