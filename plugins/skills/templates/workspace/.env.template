# Workspace identity
# Required by: init-workspace, resolve-project-env
WORKSPACE_ID=project-A
WORKSPACE_NAME=Project A

# Git identity
# Required by: resolve-project-env, approve-feature, reject-feature, pr-create, start-implementation
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# GitHub
# Required by: resolve-project-env, pr-create
GITHUB_ACCOUNT=
# Required by: resolve-project-env, pr-create, start-implementation
SSH_KEY_PATH=~/.ssh/your_key_name

# Figma (required by: figma-mcp skill)
# Get token: Figma → Account Settings → Security → Personal Access Tokens
FIGMA_PERSONAL_ACCESS_TOKEN=

# Workflow defaults
# Note: base branches are per-repo, declared in workspace.yaml (repos[].base_branch)
SKIP_STAGING=false

# Repo local paths
# Required by: resolve-project-env, start-implementation
# Add one per repo declared in workspace.yaml, e.g.:
# PROJECT_A_API_LOCAL_PATH=
# PROJECT_A_WEB_LOCAL_PATH=
# PROJECT_A_DATA_LOCAL_PATH=
